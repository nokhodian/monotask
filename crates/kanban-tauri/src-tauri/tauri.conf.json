{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "P2P Kanban",
  "version": "0.1.0",
  "identifier": "dev.p2p-kanban",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [{ "title": "P2P Kanban", "width": 1200, "height": 800 }],
    "security": { "csp": null },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
